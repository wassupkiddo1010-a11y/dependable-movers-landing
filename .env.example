NEXT_PUBLIC_SITE_URL=https://dependablemovers.com

# Quote form — n8n webhook (POST JSON payload from lib/submissions/quote-payload.ts)
# N8N_QUOTE_WEBHOOK_URL=https://your-n8n-instance/webhook/...

# Newsletter subscribe (optional separate webhook)
# N8N_SUBSCRIBE_WEBHOOK_URL=https://your-n8n-instance/webhook/...

# Supabase (server-only — never expose service role key to the client)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_QUOTE_TABLE=quote_leads
# SUPABASE_SUBSCRIBE_TABLE=newsletter_subscribers
